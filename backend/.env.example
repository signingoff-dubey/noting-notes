# INK Backend — Environment Variables

# Server (defaults: 0.0.0.0:8000)
HOST=0.0.0.0
PORT=8000

# Data directory (relative to repo root)
DATA_DIR=data

# Ollama (local AI)
OLLAMA_URL=http://localhost:11434

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Vault encryption (higher = slower, more secure)
VAULT_BCRYPT_ROUNDS=12

# Groq API key (for cloud AI provider instead of local Ollama)
# GROQ_API_KEY=gsk_...
